-- ================================================
-- ANTI RAGDOLL — actif dès le début, permanent
-- Remet debout + réactive les joints + permet de marcher immédiatement
-- ================================================
local function applyAntiRagdoll(char)
    if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")

    if hum then
        local st = hum:GetState()
        if st == Enum.HumanoidStateType.Physics
        or st == Enum.HumanoidStateType.Ragdoll
        or st == Enum.HumanoidStateType.FallingDown
        or st == Enum.HumanoidStateType.GettingUp then
            -- Force l'état Running pour pouvoir marcher immédiatement
            hum:ChangeState(Enum.HumanoidStateType.Running)
            -- Reassigne le sujet caméra
            workspace.CurrentCamera.CameraSubject = hum
            -- Stoppe toute vélocité résiduelle
            if root then
                root.AssemblyLinearVelocity  = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end
        end
        -- Annule l'attribut ragdoll si le jeu en utilise un
        pcall(function()
            if char:GetAttribute("Ragdoll")    ~= nil then char:SetAttribute("Ragdoll",    false) end
            if char:GetAttribute("ragdolled")  ~= nil then char:SetAttribute("ragdolled",  false) end
            if char:GetAttribute("Ragdolled")  ~= nil then char:SetAttribute("Ragdolled",  false) end
            if char:GetAttribute("IsRagdoll")  ~= nil then char:SetAttribute("IsRagdoll",  false) end
        end)
        -- Réactive tous les Motor6D (joints du squelette)
        for _, obj in ipairs(char:GetDescendants()) do
            if obj:IsA("Motor6D") and not obj.Enabled then
                obj.Enabled = true
            end
        end
        -- Réactive les contrôles joueur si désactivés
        pcall(function()
            local pm = Player.PlayerScripts:FindFirstChild("PlayerModule")
            if pm then
                local ctrl = require(pm:FindFirstChild("ControlModule"))
                if ctrl then ctrl:Enable() end
            end
        end)
    end
end

-- Loop Heartbeat permanente anti ragdoll
RunService.Heartbeat:Connect(function()
    applyAntiRagdoll(Player.Character)
end)

-- ================================================
-- TÉLÉPORTATION — effet "marche jusqu'au point"
-- On TP directement à la destination finale mais on
-- utilise un BodyPosition smooth pour simuler un
-- glissement rapide vers la cible (vitesse réglable)
-- ================================================
local TP_WALK_SPEED = 120  -- studs/s (plus élevé = plus rapide/instantané)

local function doSmoothTP(targetPos)
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    -- Calcule la durée en fonction de la distance
    local dist     = (Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z) - hrp.Position).Magnitude
    local duration = math.clamp(dist / TP_WALK_SPEED, 0.05, 0.25)

    -- Désactive les contrôles pendant le déplacement
    hum.WalkSpeed = 0

    -- AlignPosition pour un mouvement lisse côté physique
    local att0 = Instance.new("Attachment", hrp)
    local ap   = Instance.new("AlignPosition", hrp)
    ap.Attachment0       = att0
    ap.Position          = Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)
    ap.MaxForce          = 1e6
    ap.MaxVelocity       = TP_WALK_SPEED
    ap.Responsiveness    = 200
    ap.ApplyAtCenterOfMass = true
    ap.RigidityEnabled   = false

    -- Oriente le perso vers la destination
    local dir = Vector3.new(targetPos.X - hrp.Position.X, 0, targetPos.Z - hrp.Position.Z)
    if dir.Magnitude > 0.5 then
        hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + dir.Unit)
    end

    -- Attend la fin du glissement
    task.delay(duration, function()
        -- Nettoie
        ap:Destroy()
        att0:Destroy()

        -- TP précis sur la position finale (corrige Y aussi)
        local c2 = Player.Character
        if not c2 then return end
        local h2 = c2:FindFirstChild("HumanoidRootPart")
        local hum2 = c2:FindFirstChildOfClass("Humanoid")
        if h2 then
            h2.CFrame = CFrame.new(targetPos)
            h2.AssemblyLinearVelocity = Vector3.zero
        end
        -- Rend le contrôle au joueur
        if hum2 then
            hum2.WalkSpeed = 16
            hum2:ChangeState(Enum.HumanoidStateType.Running)
        end
    end)
end

-- ================================================
-- DÉCLENCHEUR TP
-- ================================================
local function triggerTP()
    if tpOnCooldown then return end
    if not Enabled.TPRight and not Enabled.TPLeft then return end
    tpOnCooldown = true

    if Enabled.TPRight then
        doSmoothTP(TP_RIGHT)
    else
        doSmoothTP(TP_LEFT)
    end

    task.delay(TP_COOLDOWN, function()
        tpOnCooldown = false
    end)
end

-- ================================================
-- DÉTECTION RAGDOLL — 4 méthodes combinées
-- ================================================
local wasRagdolled = false
local motorWasOff  = false

local function setupRagdollDetection(char)
    if not char then return end
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end

    wasRagdolled = false
    motorWasOff  = false

    -- Méthode 1 : StateChanged
    hum.StateChanged:Connect(function(_, newState)
        if newState == Enum.HumanoidStateType.Physics
        or newState == Enum.HumanoidStateType.Ragdoll
        or newState == Enum.HumanoidStateType.FallingDown then
            if not wasRagdolled then
                wasRagdolled = true
                triggerTP()
            end
        else
            wasRagdolled = false
        end
    end)

    -- Méthode 2 : Motor6D désactivé
    local function watchMotor(motor)
        if not motor:IsA("Motor6D") then return end
        motor:GetPropertyChangedSignal("Enabled"):Connect(function()
            if not motor.Enabled then
                if not motorWasOff then
                    motorWasOff = true
                    triggerTP()
                end
            else
                motorWasOff = false
            end
        end)
    end
    for _, d in ipairs(char:GetDescendants()) do watchMotor(d) end
    char.DescendantAdded:Connect(function(d) task.defer(function() watchMotor(d) end) end)

    -- Méthode 3 : Attribut ragdoll
    char.AttributeChanged:Connect(function(attr)
        if attr == "Ragdoll" or attr == "ragdolled" or attr == "Ragdolled" or attr == "IsRagdoll" then
            local v = char:GetAttribute(attr)
            if v == true then triggerTP() end
        end
    end)

    -- Méthode 4 : Heartbeat polling backup
    RunService.Heartbeat:Connect(function()
        if not hum or not hum.Parent then return end
        local st = hum:GetState()
        local isRag = st == Enum.HumanoidStateType.Physics
                   or st == Enum.HumanoidStateType.Ragdoll
                   or st == Enum.HumanoidStateType.FallingDown
        if isRag and not wasRagdolled then
            wasRagdolled = true
            triggerTP()
        elseif not isRag then
            wasRagdolled = false
        end
    end)
end

